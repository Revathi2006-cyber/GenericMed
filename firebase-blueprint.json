{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "description": "User email address" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "hasCompletedOnboarding": { "type": "boolean", "description": "Whether the user has completed the onboarding process" },
        "theme": { "type": "string", "enum": ["light", "dark"], "description": "User's preferred theme" },
        "fontSize": { "type": "string", "enum": ["normal", "large", "extra-large"], "description": "User's preferred font size" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "HistoryItem": {
      "title": "HistoryItem",
      "description": "A scanned prescription or searched medicine history item",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the history item" },
        "uid": { "type": "string", "description": "Owner User ID" },
        "date": { "type": "string", "format": "date-time", "description": "Date of scan/search" },
        "image": { "type": "string", "description": "Base64 image or empty string" },
        "results": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Array of medicine results"
        }
      },
      "required": ["id", "uid", "date", "image", "results"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles"
    },
    "/history/{historyId}": {
      "schema": { "$ref": "#/entities/HistoryItem" },
      "description": "User history items"
    }
  }
}
